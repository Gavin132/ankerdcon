# Google Sheets — paste the full service account JSON as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Auth
APP_PASSPHRASE=your_secret_group_passphrase
JWT_SECRET_KEY=change_this_to_a_random_64_char_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Integrations (optional)
DISCORD_WEBHOOK_URL=
APP_URL=

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173
